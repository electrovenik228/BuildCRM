# Django
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=127.0.0.1,localhost,.onrender.com
CSRF_TRUSTED_ORIGINS=

# SQLite-only minimal deployment
SQLITE_PATH=db.sqlite3

# Render admin bootstrap
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-password

# Gemini AI chat
# If GEMINI_API_KEY is empty, /api/ai/chat/ works in local rule-based mode only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Redis / Celery placeholders for later stages
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Localization
TIME_ZONE=Asia/Bishkek
LANGUAGE_CODE=ru-ru
