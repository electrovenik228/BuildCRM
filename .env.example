# Django
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
# Current project default is SQLite. Keep DATABASE_URL empty to use db.sqlite3.
DATABASE_URL=

# PostgreSQL example for later migration:
# DATABASE_URL=postgres://buildcrm:buildcrm_password@127.0.0.1:5432/buildcrm
POSTGRES_DB=buildcrm
POSTGRES_USER=buildcrm
POSTGRES_PASSWORD=buildcrm_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Gemini AI chat
# If GEMINI_API_KEY is empty, /api/ai/chat/ works in local rule-based mode only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Redis / Celery placeholders for later stages
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Localization
TIME_ZONE=Asia/Bishkek
LANGUAGE_CODE=ru-ru
